# ====================================================================
# General & OS-Specific
# ====================================================================
# Files generated by Operating Systems
.DS_Store
Thumbs.db
Desktop.ini

# Log files
*.log
logs/
*.log.*

# ====================================================================
# Development Environment
# ====================================================================
# Environment variables - NEVER commit secrets!
.env
.env.*
!.env.example

# VSCode editor configuration
.vscode/.browse.c_cpp.db*
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Gemini tool cache/config
.gemini/

# Claude Code local state
.claude/

# clangd index cache
firmware/.cache/

# ESP-IDF extension generated VS Code config inside firmware/
firmware/.vscode/

# ====================================================================
# Python Specific
# ====================================================================
# Virtual environments
.venv/
backend/env/

# Python cache files
__pycache__/
*.pyc

# Python distribution/build artifacts
build/
dist/
*.egg-info/

# Testing artifacts
.pytest_cache/
.coverage
htmlcov/

# ====================================================================
# SSH Keys
# ====================================================================
# Private keys — NEVER commit!
.ssh/rpi-gateway

# ====================================================================
# Firmware / ESP-IDF
# ====================================================================
# Old PlatformIO artifacts
.pio/
.dependencies/
firmware/.pio/
firmware/dependencies/
firmware/test/

# ESP-IDF generated files
firmware/build/
firmware/sdkconfig
firmware/sdkconfig.old
firmware/managed_components/
